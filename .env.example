# Copier en .env pour le développement local (jamais commité)
# Ports hôtes remappés (5432/6379 déjà pris par un autre projet)
DATABASE_URL=postgresql://ensemb:ensemb_dev@localhost:5433/ensemb
REDIS_URL=redis://localhost:6380
PORT=3000
NODE_ENV=development
APP_ENCRYPTION_KEY=change_me_32_chars_minimum_secret

# Stockage objet S3-compatible — MinIO en dev (§17 point Y)
# En prod : remplacer par les credentials du bucket S3 de production
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=ensemb-uploads
S3_ACCESS_KEY_ID=ensemb
S3_SECRET_ACCESS_KEY=ensemb_dev
S3_SIGNED_URL_TTL=3600
