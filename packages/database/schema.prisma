generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Référentiels globaux ─────────────────────────────────────────────────────

enum CurrencySymbolPosition {
  BEFORE
  AFTER
}

/// Devise globale de plateforme (partagée entre tous les tenants).
/// Seul un PlatformAdmin peut créer/modifier/désactiver une devise.
/// Un tenant choisit sa devise par défaut via Organization.defaultCurrencyId.
model Currency {
  id             String                 @id @default(uuid()) @db.Uuid
  /// Code ISO 4217 : "XAF", "EUR", "USD"
  code           String                 @unique
  /// Libellé complet : "Franc CFA BEAC", "Euro"
  name           String
  /// Symbole affiché : "XAF", "€", "$"
  symbol         String
  /// Position du symbole : BEFORE = "$ 5 000", AFTER = "5 000 XAF"
  symbolPosition CurrencySymbolPosition @default(AFTER)
  /// Nombre de décimales affichées (0 pour XAF)
  decimalPlaces  Int                    @default(0)
  /// false = devise masquée dans l'UI (soft-disable)
  isActive       Boolean                @default(true)
  organizations  Organization[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@map("currencies")
}

// ─── Tenants & plateforme ────────────────────────────────────────────────────

enum OrganizationStatus {
  TRIALING
  ACTIVE
  SUSPENDED
  CANCELED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

/// Plan tarifaire de la plateforme. Valeurs modifiables par le staff plateforme sans déploiement.
model Plan {
  id                    String         @id @default(uuid()) @db.Uuid
  /// Clé technique : "starter", "pro", "enterprise"
  name                  String         @unique
  /// Libellé affiché : "Starter", "Pro", "Enterprise"
  label                 String
  /// Prix mensuel en XAF (Decimal obligatoire — règle §17 point A)
  priceMonthly          Decimal        @db.Decimal(10, 2)
  /// Prix annuel en XAF
  priceAnnual           Decimal        @db.Decimal(10, 2)
  /// Durée d'essai standard après la fenêtre de lancement
  trialDurationDays     Int            @default(30)
  /// Plafond CA d'essai en XAF ; null = illimité (fenêtre de lancement ou enterprise)
  trialRevenueCapAmount Decimal?       @db.Decimal(12, 2)
  /// Nombre maximum d'utilisateurs ; null = illimité
  maxUsers              Int?
  /// Nombre maximum d'entrepôts ; null = illimité
  maxWarehouses         Int?
  /// Nombre maximum de produits ; null = illimité
  maxProducts           Int?
  isActive              Boolean        @default(true)
  subscriptions         Subscription[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@map("plans")
}

/// Abonnement actif d'une organisation. Une seule subscription active par org (contrainte unique).
model Subscription {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @unique @db.Uuid
  planId            String             @db.Uuid
  status            SubscriptionStatus @default(TRIALING)
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean            @default(false)
  organization      Organization       @relation(fields: [organizationId], references: [id])
  plan              Plan               @relation(fields: [planId], references: [id])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  invoices          Invoice[]

  @@index([planId])
  @@map("subscriptions")
}

/// Facture générée pour une période d'abonnement. Persist avant activation.
model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  subscriptionId String        @db.Uuid
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("XAF")
  status         InvoiceStatus @default(PENDING)
  /// URL de paiement générée par l'agrégateur
  paymentLink    String?
  paidAt         DateTime?
  dueAt          DateTime
  /// "monthly" | "annual" — conservé pour la relance automatique (invoice.renew)
  period         String        @default("monthly")
  organization   Organization  @relation(fields: [organizationId], references: [id])
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  webhookEvents  WebhookEvent[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, status])
  @@map("invoices")
}

/// Événement webhook persisté avant tout traitement (idempotence §17 point V).
/// La contrainte unique (provider, providerEventId) garantit qu'un rejeu est ignoré.
model WebhookEvent {
  id              String    @id @default(uuid()) @db.Uuid
  provider        String
  providerEventId String
  payload         Json
  /// Horodatage de réception du webhook (avant traitement)
  receivedAt      DateTime  @default(now())
  /// Horodatage de fin de traitement métier ; null si le traitement a échoué ou est ignoré
  processedAt     DateTime?
  /// Tenant concerné — scopé quand l'invoiceId est résolvable
  organizationId  String?   @db.Uuid
  invoiceId       String?   @db.Uuid
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])

  @@unique([provider, providerEventId])
  @@map("webhook_events")
}

/// Paramètres plateforme modifiables sans redéploiement (clé/valeur JSON sérialisé).
/// Ex. : launchPromoEndsAt = "2026-09-30T23:59:59Z"
model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

/// Organisation cliente (tenant). Chaque modèle métier est scopé par organizationId.
model Organization {
  id           String             @id @default(uuid()) @db.Uuid
  name         String
  /// Sous-domaine unique : boutique-durand → boutique-durand.monapp.com
  subdomain    String             @unique
  customDomain String?            @unique
  logoUrl      String?
  /// Couleur principale HSL/hex appliquée au runtime (design system §3)
  primaryColor String?
  status            OrganizationStatus @default(TRIALING)
  /// Date de fin d'essai calculée à l'inscription. Null pour les orgs antérieures à T04.
  /// Logique fenêtre de lancement différée à T06 (PlatformSetting.launchPromoEndsAt).
  trialEndsAt       DateTime?
  /// Raison d'une fin d'essai anticipée (ex. dépassement CA). Alimenté par billing-queue (T06/T07).
  trialEndedReason  String?
  /// Devise par défaut choisie par l'organisation (lecture seule pour les tenants non-admin).
  defaultCurrencyId String?   @db.Uuid
  defaultCurrency   Currency? @relation(fields: [defaultCurrencyId], references: [id])
  createdAt         DateTime  @default(now())
  deletedAt         DateTime?

  users            User[]
  roles            Role[]
  subscription     Subscription?
  invoices         Invoice[]
  smtpServer       SmtpServer?
  backupExports    BackupExport[]
  warehouses       Warehouse[]
  categories       Category[]
  brands           Brand[]
  units            Unit[]
  products         Product[]
  clients          Client[]
  providers        Provider[]
  documentCounters DocumentCounter[]
  adjustments      Adjustment[]
  transfers        StockTransfer[]
  notifications    Notification[]

  @@map("organizations")
}

/// Configuration SMTP par organisation — mot de passe chiffré AES-256-GCM (§17 point S).
/// Ne jamais exposer passwordCipher dans une réponse HTTP.
model SmtpServer {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @db.Uuid
  host           String
  port           Int          @default(587)
  username       String
  /// Chiffré en AES-256-GCM — format stocké : "iv:authTag:ciphertext" (hex)
  passwordCipher String
  fromEmail      String
  fromName       String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("smtp_servers")
}

/// Compte staff plateforme — auth séparée de celle des utilisateurs tenant.
model PlatformAdmin {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  /// Mot de passe hashé (bcrypt cost 12)
  password    String
  /// Secret TOTP chiffré AES-256-GCM via EncryptionService. Null si TOTP pas encore configuré.
  totpSecret  String?
  /// True dès que le TOTP a été vérifié une première fois (setup confirmé).
  totpEnabled Boolean  @default(false)
  /// False = compte désactivé, 401 générique au login.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("platform_admins")
}

// ─── Identité & contrôle d'accès ─────────────────────────────────────────────

/// Référentiel global des permissions — non scopé par organisation.
model Permission {
  id    String  @id @default(uuid()) @db.Uuid
  /// Clé technique unique, ex. "invoices.create"
  name  String  @unique
  /// Libellé lisible pour l'UI d'administration
  label String?

  roles PermissionOnRole[]

  @@map("permissions")
}

/// Utilisateur appartenant à un tenant (scopé par organizationId).
model User {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  firstname      String
  lastname       String
  email          String
  username       String
  /// Mot de passe hashé (bcrypt)
  password       String
  avatar         String?
  phone          String?
  /// false = compte désactivé (soft-disable sans suppression)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization  Organization   @relation(fields: [organizationId], references: [id])
  roles         RoleOnUser[]
  adjustments   Adjustment[]
  transfers     StockTransfer[]
  notifications Notification[]

  /// Un email est unique au sein d'un tenant, pas globalement.
  @@unique([organizationId, email])
  /// Un username est unique au sein d'un tenant.
  @@unique([organizationId, username])
  @@map("users")
}

/// Rôle nommé, scopé par organisation.
model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  label          String?
  description    String?
  /// false = rôle désactivé
  status         Boolean  @default(true)

  organization Organization      @relation(fields: [organizationId], references: [id])
  permissions  PermissionOnRole[]
  users        RoleOnUser[]

  @@unique([organizationId, name])
  @@map("roles")
}

/// Table de jonction User ↔ Role (relation N:N).
model RoleOnUser {
  userId String @db.Uuid
  roleId String @db.Uuid

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("roles_on_users")
}

/// Table de jonction Role ↔ Permission (relation N:N).
model PermissionOnRole {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("permissions_on_roles")
}

/// Journal d'audit des mutations sensibles (§17 point U).
/// organizationId est nullable pour les actions du staff plateforme.
model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid
  actorType      String                            // "USER" | "PLATFORM_ADMIN" | "SYSTEM"
  actorId        String?  @db.Uuid
  action         String                            // ex. "roles.update", "permissions.assign"
  entity         String                            // nom du modèle, ex. "Role"
  entityId       String?  @db.Uuid
  before         Json?
  after          Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─── Sauvegarde / exports (T09) ──────────────────────────────────────────────

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ExportFormat {
  CSV
  JSON
}

/// Export de données par organisation (§17 point N).
/// Un export ne contient jamais de données d'un autre tenant.
/// Stockage local storage/exports/<organizationId>/<exportId>.<ext> — TODO T09-debt: migrer vers S3-compatible (S13, §17 point Y).
model BackupExport {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  status         ExportStatus @default(PENDING)
  format         ExportFormat @default(CSV)
  /// Nom du fichier généré — null tant que le job n'a pas produit le fichier.
  filename       String?
  /// Taille en octets du fichier généré — null avant complétion.
  sizeBytes      Int?
  /// Message d'erreur interne — ne jamais exposer dans une réponse HTTP.
  errorMessage   String?
  requestedAt    DateTime     @default(now())
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, requestedAt(sort: Desc)])
  @@map("backup_exports")
}

// ─── Référentiels tenant ──────────────────────────────────────────────────────

/// Entrepôt physique ou logique d'un tenant.
/// Soft delete : deletedAt DateTime? — pas de suppression physique (§17 point 7).
/// version Int : verrouillage optimiste pour les mouvements de stock (S15, §17 point B).
/// L'index unique partiel (organizationId, name) WHERE deleted_at IS NULL est créé
/// en SQL raw dans la migration (Prisma ne supporte pas les index partiels dans @@unique).
model Warehouse {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  address        String?
  /// true = entrepôt par défaut de l'organisation (un seul par org, géré transactionnellement)
  isDefault      Boolean      @default(false)
  /// Compteur de version pour le verrouillage optimiste sur les mouvements de stock (S15)
  version        Int          @default(0)
  deletedAt      DateTime?
  organization    Organization      @relation(fields: [organizationId], references: [id])
  stocks          ProductWarehouse[]
  adjustments     Adjustment[]
  transfersFrom   StockTransfer[]   @relation("TransferFrom")
  transfersTo     StockTransfer[]   @relation("TransferTo")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId])
  @@map("warehouses")
}

// ─── Catalogue tenant ─────────────────────────────────────────────────────────

/// Catégorie de produit, scopée par organisation (S10 — Bloc C).
/// Soft delete : index uniques partiels (organizationId, code) et (organizationId, name)
/// créés en SQL raw dans la migration (Prisma ne supporte pas les index partiels dans @@unique).
model Category {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  /// Code métier court, ex. "ELEC", "ALI" — majuscules et chiffres uniquement, 1–20 chars.
  code           String
  name           String
  deletedAt      DateTime?
  products       Product[]
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("categories")
}

/// Marque de produit, scopée par organisation (S10 — Bloc C).
/// image String? : URL logo — upload réel reporté à S13 (TODO S10-debt: upload réel S13).
model Brand {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  description    String?
  /// URL d'un logo de marque — TODO S10-debt: upload réel via stockage S13.
  image          String?
  deletedAt      DateTime?
  products       Product[]
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("brands")
}

/// Produit du catalogue tenant (S14 — Bloc D).
/// image String? : clé S3 — jamais URL directe (§17 point Y). URL signée générée à la volée.
/// cost / price / taxRate : Decimal obligatoire — jamais Float (§17 point A).
/// Soft delete : index unique partiel (organizationId, name) WHERE deleted_at IS NULL en SQL raw.
/// Un produit isVariant: true a des ProductVariant ; le stock réel est dans ProductWarehouse (S15).
model Product {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @db.Uuid
  /// Code de référence interne — unique par organisation (actifs)
  code            String
  /// Format du code-barres affiché côté client (ex. "EAN13", "CODE128", "QR")
  barcodeType     String?
  name            String
  /// Prix d'achat HT — Decimal obligatoire (§17 point A)
  cost            Decimal   @db.Decimal(14, 3)
  /// Prix de vente HT — Decimal obligatoire (§17 point A)
  price           Decimal   @db.Decimal(14, 3)
  categoryId      String    @db.Uuid
  brandId         String?   @db.Uuid
  /// Unité de stock par défaut (ex. "Pièce")
  unitId          String?   @db.Uuid
  /// Unité de vente (ex. "Carton") — peut différer de l'unité de stock
  unitSaleId      String?   @db.Uuid
  /// Unité d'achat (ex. "Carton") — peut différer de l'unité de stock
  unitPurchaseId  String?   @db.Uuid
  /// Taux de TVA — ex. 0.1925 = 19,25 % — Decimal obligatoire (§17 point A)
  taxRate         Decimal   @default(0) @db.Decimal(5, 4)
  /// "percentage" | "fixed"
  taxMethod       String    @default("percentage")
  /// Clé S3 de l'image produit — jamais URL directe (§17 point Y)
  image           String?
  note            String?
  /// Seuil d'alerte de stock bas (entier, 0 = désactivé)
  stockAlert      Int       @default(0)
  /// true = produit avec variantes (tailles, couleurs…)
  isVariant       Boolean   @default(false)
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id])
  category       Category         @relation(fields: [categoryId], references: [id])
  brand          Brand?           @relation(fields: [brandId], references: [id])
  unit           Unit?            @relation("ProductUnit", fields: [unitId], references: [id])
  unitSale       Unit?            @relation("ProductUnitSale", fields: [unitSaleId], references: [id])
  unitPurchase   Unit?            @relation("ProductUnitPurchase", fields: [unitPurchaseId], references: [id])
  variants           ProductVariant[]
  stocks             ProductWarehouse[]
  adjustmentDetails  AdjustmentDetail[]
  transferDetails    StockTransferDetail[]

  /// Unicité (organizationId, code) — actifs et supprimés confondus (code non libéré par soft-delete)
  @@unique([organizationId, code])
  @@map("products")
}

/// Variante d'un produit (S14 — Bloc D).
/// Pas de champ quantity — unique source de vérité du stock = ProductWarehouse.productVariantId (S15).
model ProductVariant {
  id        String    @id @default(uuid()) @db.Uuid
  productId String    @db.Uuid
  /// Libellé de la variante (ex. "Rouge / L", "500 ml")
  name      String?
  deletedAt DateTime?

  product Product          @relation(fields: [productId], references: [id])
  stocks  ProductWarehouse[]

  @@map("product_variants")
}

/// Stock d'un produit (ou d'une variante) dans un entrepôt (S14 stub — géré en S15).
/// version Int : verrouillage optimiste pour tout mouvement de stock (§17 point B).
/// quantity Decimal — jamais Float (§17 point A).
model ProductWarehouse {
  id               String         @id @default(uuid()) @db.Uuid
  productId        String         @db.Uuid
  warehouseId      String         @db.Uuid
  productVariantId String?        @db.Uuid
  /// Quantité en stock — Decimal obligatoire (§17 point A)
  quantity         Decimal        @default(0) @db.Decimal(14, 3)
  /// Compteur de version pour le verrouillage optimiste (S15, §17 point B)
  version          Int            @default(0)

  product   Product         @relation(fields: [productId], references: [id])
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  variant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  /// Unicité appliquée par deux index partiels SQL (migration S14) :
  ///   "product_warehouse_no_variant_unique"   WHERE productVariantId IS NULL
  ///   "product_warehouse_with_variant_unique" WHERE productVariantId IS NOT NULL
  /// (PostgreSQL traite NULL ≠ NULL dans les contraintes UNIQUE — index partiels nécessaires)
  @@map("product_warehouse")
}

/// Unité de mesure / conditionnement, scopée par organisation (S11 — Bloc C).
/// Hiérarchie auto-référentielle max 1 niveau : une unité de base (baseUnitId = null)
/// ou une unité dérivée (baseUnitId non nul) — ex. Carton = 12 × Pièce.
/// operator "*" ou "/" ; operatorValue Decimal (facteur de conversion, §17 point A).
/// Soft delete : index uniques partiels (organizationId, name) et (organizationId, shortName)
/// créés en SQL raw dans la migration (WHERE deleted_at IS NULL).
model Unit {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  /// Libellé complet : "Pièce", "Carton", "Litre"
  name           String
  /// Nom court affiché : "pcs", "ctn", "L"
  shortName      String
  /// Null = unité de base ; non nul = unité dérivée (1 niveau max)
  baseUnitId     String?   @db.Uuid
  baseUnit       Unit?     @relation("UnitHierarchy", fields: [baseUnitId], references: [id])
  subUnits       Unit[]    @relation("UnitHierarchy")
  /// Opérateur de conversion : "*" (multiplication) ou "/" (division)
  operator       String    @default("*")
  /// Facteur de conversion — Decimal obligatoire (§17 point A)
  operatorValue  Decimal   @default(1) @db.Decimal(14, 6)
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id])
  /// Produits référençant cette unité (stub S11 — colonnes complètes en S14)
  products         Product[] @relation("ProductUnit")
  productsSale     Product[] @relation("ProductUnitSale")
  productsPurchase Product[] @relation("ProductUnitPurchase")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("units")
}

// ─── Partenaires tenant ───────────────────────────────────────────────────────

/// Client d'un tenant (S12 — Bloc C).
/// code : entier séquentiel par organisation, généré en transaction SERIALIZABLE.
/// Soft delete : index uniques partiels (organizationId, name) et (organizationId, code)
/// créés en SQL raw dans la migration (WHERE deleted_at IS NULL).
/// Le client "Walk-in" (code=1) est le client anonyme du POS — seedé automatiquement.
model Client {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  name           String
  /// Code séquentiel par organisation — généré transactionnellement, jamais saisi par l'utilisateur
  code           Int
  email          String?
  phone          String?
  country        String?
  city           String?
  address        String?
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  /// Contrainte de sécurité : le filet final en cas de collision concurrente sur le code
  @@unique([organizationId, code])
  @@map("clients")
}

/// Fournisseur d'un tenant (S12 — Bloc C).
/// Même structure que Client — code séquentiel distinct par organisation.
model Provider {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  name           String
  /// Code séquentiel par organisation — généré transactionnellement, jamais saisi par l'utilisateur
  code           Int
  email          String?
  phone          String?
  country        String?
  city           String?
  address        String?
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([organizationId, code])
  @@map("providers")
}

// ─── Génération transactionnelle des références de documents (§17 point X) ──

/// Types de documents financiers générant une référence séquentielle.
enum DocumentType {
  SALE
  PURCHASE
  QUOTATION
  SALE_RETURN
  PURCHASE_RETURN
  TRANSFER
  ADJUSTMENT
}

/// Compteur de référence par (organisation, type de document, année civile).
/// Incrémenté dans la même transaction que la création du document (SELECT … FOR UPDATE ou upsert+increment).
/// Jamais de MAX(reference)+1 applicatif — source de collision en concurrence (§17 point X).
model DocumentCounter {
  organizationId String       @db.Uuid
  documentType   DocumentType
  year           Int
  /// Dernier compteur utilisé — incrémenté atomiquement dans la transaction de création.
  lastCounter    Int          @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@id([organizationId, documentType, year])
  @@map("document_counters")
}

// ─── Ajustements de stock (S16 — Bloc D) ─────────────────────────────────────

/// Statut d'un ajustement de stock.
/// DRAFT = brouillon (pas encore appliqué au stock).
/// VALIDATED = appliqué — immuable, ni modification ni suppression physique possible.
enum AdjustmentStatus {
  DRAFT
  VALIDATED
}

/// Sens du mouvement d'une ligne d'ajustement.
enum AdjustmentDetailType {
  ADDITION
  SOUSTRACTION
}

/// En-tête d'un ajustement de stock (S16 — Bloc D).
/// Patron identique à Sale/SaleDetail : l'organizationId est sur l'en-tête uniquement.
/// reference générée via DocumentCounterService.nextReference dans la transaction de création (§17 point X).
/// Soft delete uniquement (deletedAt) — un ajustement validé ne peut être ni modifié ni supprimé (§17 point 7).
model Adjustment {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  /// Référence unique par organisation — générée via DocumentCounter (ex. "ADJ-2026-000001")
  reference      String
  date           DateTime
  warehouseId    String           @db.Uuid
  userId         String           @db.Uuid
  note           String?
  status         AdjustmentStatus @default(DRAFT)
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id])
  user         User               @relation(fields: [userId], references: [id])
  details      AdjustmentDetail[]

  @@unique([organizationId, reference])
  @@index([organizationId, status])
  @@map("adjustments")
}

/// Ligne d'un ajustement de stock (S16 — Bloc D).
/// quantity et unitCost en Decimal — jamais Float (§17 point A).
/// L'organizationId n'est pas répété ici — hérité via adjustment.organizationId.
model AdjustmentDetail {
  id               String               @id @default(uuid()) @db.Uuid
  adjustmentId     String               @db.Uuid
  productId        String               @db.Uuid
  productVariantId String?              @db.Uuid
  type             AdjustmentDetailType
  /// Quantité ajustée — Decimal obligatoire (§17 point A), toujours positive
  quantity         Decimal              @db.Decimal(14, 3)
  /// Coût unitaire pour valorisation — Decimal obligatoire (§17 point A)
  unitCost         Decimal              @default(0) @db.Decimal(14, 3)

  adjustment Adjustment     @relation(fields: [adjustmentId], references: [id])
  product    Product        @relation(fields: [productId], references: [id])

  @@map("adjustment_details")
}

// ─── Transferts de stock entre entrepôts (S17 — Bloc D) ──────────────────────

/// Statut d'un transfert de stock.
/// DRAFT = brouillon (pas encore appliqué au stock).
/// VALIDATED = appliqué — immuable, ni modification ni suppression physique possible.
enum TransferStatus {
  DRAFT
  VALIDATED
}

/// En-tête d'un transfert de stock (S17 — Bloc D).
/// Patron identique à Sale/SaleDetail : organizationId sur l'en-tête uniquement.
/// reference générée via DocumentCounterService.nextReference (§17 point X) — format TRF-YYYY-NNNNNN.
/// Atomicité : validation décrémente fromWarehouse ET incrémente toWarehouse dans la même transaction.
/// Soft delete uniquement (deletedAt) — un transfert validé ne peut être ni modifié ni supprimé (§17 point 7).
model StockTransfer {
  id              String         @id @default(uuid()) @db.Uuid
  organizationId  String         @db.Uuid
  /// Référence unique par organisation — générée via DocumentCounter (ex. "TRF-2026-000001")
  reference       String
  date            DateTime
  fromWarehouseId String         @db.Uuid
  toWarehouseId   String         @db.Uuid
  userId          String         @db.Uuid
  note            String?
  status          TransferStatus @default(DRAFT)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id])
  fromWarehouse Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  user          User                @relation(fields: [userId], references: [id])
  details       StockTransferDetail[]

  @@unique([organizationId, reference])
  @@index([organizationId, status])
  @@map("stock_transfers")
}

/// Ligne d'un transfert de stock (S17 — Bloc D).
/// quantity en Decimal — jamais Float (§17 point A).
/// L'organizationId n'est pas répété ici — hérité via transfer.organizationId.
model StockTransferDetail {
  id               String        @id @default(uuid()) @db.Uuid
  transferId       String        @db.Uuid
  productId        String        @db.Uuid
  productVariantId String?       @db.Uuid
  /// Quantité transférée — Decimal obligatoire (§17 point A), toujours positive
  quantity         Decimal       @db.Decimal(14, 3)

  transfer StockTransfer  @relation(fields: [transferId], references: [id])
  product  Product        @relation(fields: [productId], references: [id])

  @@map("stock_transfer_details")
}

// ─── Notifications (S18 — Bloc D) ────────────────────────────────────────────

/// Notification persistante par utilisateur (§17 point I — S18).
/// Persiste ce que Socket.io ne fait que diffuser en direct : si aucun client
/// n'est connecté au moment de l'émission, la notification est retrouvée
/// à la prochaine connexion.
/// type : "stock.lowAlert" | "backup.completed" | …
/// payload : données spécifiques au type (ex. { productId, productName, … })
model Notification {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  /// Catégorie machine-readable : "stock.lowAlert", "backup.completed", …
  type           String
  /// Données spécifiques au type — structure définie par le service émetteur.
  payload        Json
  /// Null = non lue ; posé à now() par markAsRead / markAllAsRead.
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, userId, readAt])
  @@map("notifications")
}
