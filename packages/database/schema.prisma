generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenants & plateforme ────────────────────────────────────────────────────

enum OrganizationStatus {
  TRIALING
  ACTIVE
  SUSPENDED
  CANCELED
}

/// Organisation cliente (tenant). Chaque modèle métier est scopé par organizationId.
model Organization {
  id           String             @id @default(uuid()) @db.Uuid
  name         String
  /// Sous-domaine unique : boutique-durand → boutique-durand.monapp.com
  subdomain    String             @unique
  customDomain String?            @unique
  logoUrl      String?
  /// Couleur principale HSL/hex appliquée au runtime (design system §3)
  primaryColor String?
  status       OrganizationStatus @default(TRIALING)
  createdAt    DateTime           @default(now())
  deletedAt    DateTime?

  @@map("organizations")
}

/// Compte staff plateforme — auth séparée de celle des utilisateurs tenant.
model PlatformAdmin {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  /// Mot de passe hashé (bcrypt)
  password  String
  createdAt DateTime @default(now())

  @@map("platform_admins")
}
