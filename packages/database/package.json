{
  "name": "@ensemb/database",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "echo 'database: no build (prisma generate handled by db:generate)'",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "typecheck": "tsc --noEmit",
    "test:integration": "jest --config jest.config.js"
  },
